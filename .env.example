# Copy to .env and adjust. docker-compose reads .env automatically.
POSTGRES_USER=weather
POSTGRES_PASSWORD=change-me
POSTGRES_DB=weather

GRAFANA_USER=admin
GRAFANA_PASSWORD=change-me

# Read-only DB role Grafana connects as (created by db/init/06-grafana-ro.sql). If you change the
# password, it is applied to the role on the next `docker compose up` (the migrate service passes
# it through). Defaults to grafana_ro/grafana_ro if unset.
# GRAFANA_DB_USER=grafana_ro
# GRAFANA_DB_PASSWORD=change-me

# Webhook for low-battery alerts (WS69 / WN31 / WH51). Point at Slack/Discord/ntfy/Home
# Assistant/etc. Leave unset to use a harmless placeholder — alerts still fire and show in
# the Grafana UI, they just don't get delivered. Do NOT set it to an empty string.
# BATTERY_ALERT_WEBHOOK=https://ntfy.sh/my-weather-station
